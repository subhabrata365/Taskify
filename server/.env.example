# Paste your Railway PostgreSQL URL here (see README)
# For local dev use the PUBLIC URL from Railway → Postgres → Connect → Public Network
# Append ?sslmode=require if not already present
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?sslmode=require"

JWT_SECRET="replace-with-generated-secret"
PORT=5000
CLIENT_URL="http://localhost:5173"
